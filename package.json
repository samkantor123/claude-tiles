{
  "name": "claude-tiles",
  "displayName": "Claude Tiles",
  "description": "Color-coded window manager for Claude Code power users. See every vibe coding session at a glance.",
  "version": "0.1.0",
  "publisher": "samkantor123",
  "repository": {
    "type": "git",
    "url": "https://github.com/samkantor123/claude-tiles"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "extensionKind": ["ui"],
  "categories": ["Other"],
  "keywords": ["claude", "claude-code", "window-manager", "context", "vibe-coding", "multi-window", "tiles", "productivity"],
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "esbuild": "^0.19.0"
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claude-tiles",
          "title": "Tiles",
          "icon": "media/claude-tiles-icon.svg"
        }
      ]
    },
    "views": {
      "claude-tiles": [
        {
          "type": "webview",
          "id": "claudeTiles.windowList",
          "name": ""
        }
      ]
    },
    "commands": [
      {
        "command": "claudeTiles.switchWindow",
        "title": "Switch to Tile",
        "category": "Claude Tiles"
      },
      {
        "command": "claudeTiles.assignColorById",
        "title": "Assign Color",
        "category": "Claude Tiles"
      },
      {
        "command": "claudeTiles.setLabelById",
        "title": "Set Label",
        "category": "Claude Tiles"
      },
      {
        "command": "claudeTiles.refresh",
        "title": "Refresh Tiles",
        "category": "Claude Tiles"
      },
      {
        "command": "claudeTiles.openPrById",
        "title": "Open PR in Browser",
        "category": "Claude Tiles"
      }
    ],
    "colors": [
      {
        "id": "claudeTiles.blue",
        "description": "Soft blue tile color",
        "defaults": { "dark": "#7eb8da", "light": "#5a9abf", "highContrast": "#7eb8da", "highContrastLight": "#5a9abf" }
      },
      {
        "id": "claudeTiles.green",
        "description": "Sage green tile color",
        "defaults": { "dark": "#8bbf9f", "light": "#6a9e80", "highContrast": "#8bbf9f", "highContrastLight": "#6a9e80" }
      },
      {
        "id": "claudeTiles.purple",
        "description": "Lavender tile color",
        "defaults": { "dark": "#b4a7d6", "light": "#9688b8", "highContrast": "#b4a7d6", "highContrastLight": "#9688b8" }
      },
      {
        "id": "claudeTiles.cyan",
        "description": "Teal tile color",
        "defaults": { "dark": "#82c4c3", "light": "#5fa3a2", "highContrast": "#82c4c3", "highContrastLight": "#5fa3a2" }
      },
      {
        "id": "claudeTiles.pink",
        "description": "Dusty rose tile color",
        "defaults": { "dark": "#d4a0b9", "light": "#b8849d", "highContrast": "#d4a0b9", "highContrastLight": "#b8849d" }
      },
      {
        "id": "claudeTiles.orange",
        "description": "Warm sand tile color",
        "defaults": { "dark": "#d4b08c", "light": "#b8946e", "highContrast": "#d4b08c", "highContrastLight": "#b8946e" }
      },
      {
        "id": "claudeTiles.yellow",
        "description": "Soft gold tile color",
        "defaults": { "dark": "#c9c08f", "light": "#a8a070", "highContrast": "#c9c08f", "highContrastLight": "#a8a070" }
      },
      {
        "id": "claudeTiles.red",
        "description": "Warm clay tile color",
        "defaults": { "dark": "#c9908f", "light": "#a87271", "highContrast": "#c9908f", "highContrastLight": "#a87271" }
      }
    ]
  }
}
